# ===========================================================================
# Web-Based Supply Chain Platform - backend environment variables
# For local development the defaults below are fine. Fill in the third-party
# keys to enable real payments / SMS / email; without them the platform runs
# in "simulation" mode and logs what it would have sent.
# ===========================================================================

DEBUG=True
SECRET_KEY=django-insecure-change-me-in-production-0a8sd7f60as98df6
ALLOWED_HOSTS=localhost,127.0.0.1

# Leave DATABASE_URL empty to use SQLite. For PostgreSQL use:
# DATABASE_URL=postgres://USER:PASSWORD@localhost:5432/agric_platform
DATABASE_URL=

CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
FRONTEND_URL=http://localhost:5173

# Commission configuration (percentages)
PLATFORM_COMMISSION_PERCENT=5
REFERRAL_COMMISSION_PERCENT=2

# ---- Paystack (payment gateway) ----
PAYSTACK_SECRET_KEY=sk_test_552ada5cbd1a49a34db6637077060be31cb8bd47
PAYSTACK_PUBLIC_KEY=pk_test_35c6e38440ab7ecae3cdea105b14b3a8de01cb34
# ---- Africa's Talking (SMS) ----
AT_USERNAME=sandbox
AT_API_KEY=
AT_SENDER_ID=

# ---- SendGrid (email) ----
SENDGRID_API_KEY=
DEFAULT_FROM_EMAIL=noreply@agric-platform.co.ke
